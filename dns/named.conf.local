zone "team9.net" IN {
    type master;
    file "/etc/bind/internal.zone";
};

zone "team9.ncaecybergames.org" IN {
    type master;
    file "/etc/bind/external.zone";
};

zone "18.172.in-addr.arpa" IN {
    type master;
    file "/etc/bind/rev.external.zone";
};

zone "168.192.in-addr.arpa" IN {
    type master;
    file "/etc/bind/rev.internal.zone";
};
