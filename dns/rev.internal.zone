$TTL 300
@   IN  SOA trench-dns.team9.net. root.localhost. (
            1 ; Serial 
            30      ; Refresh
            60      ; Retry
            300     ; Expire
            86400 )    ; Minimum TTL

; Name Servers
@   IN  NS  trench-dns.team9.net.

; PTR Records (Pointer Records for Reverse DNS)
1.9   IN  PTR gateway.team9.net
5.9   IN  PTR www.team9.net
7.9   IN  PTR db.team9.net
12.9   IN  PTR ns1.team9.net
